{
  "name": "Modis",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "ios-release": "react-native run-ios --configuration Release",
    "ios-clean": "cd ios && rm -rf build && rm -rf DerivedData && rm -rf Pods && rm -f Podfile.lock && pod install && cd ..",
    "ios-check": "bash scripts/check-ios-build.sh",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "postinstall": "node -e \"const { execSync } = require('child_process'); try { execSync('pod --version', { stdio: 'ignore' }); console.log('Installing CocoaPods dependencies...'); execSync('cd ios && pod install --repo-update', { stdio: 'inherit' }); } catch (e) { console.log('CocoaPods not found, skipping pod install'); }\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-camera-roll/camera-roll": "^7.10.2",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/new-app-screen": "0.81.4",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.5.1",
    "@stomp/stompjs": "^7.2.1",
    "axios": "^1.13.2",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "^4.1.3",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "react-native-share": "^12.2.2",
    "react-native-vector-icons": "^10.3.0",
    "react-native-vision-camera": "^4.7.2",
    "react-native-worklets": "^0.8.0",
    "react-native-worklets-core": "^1.6.3",
    "rn-emoji-keyboard": "^1.7.0",
    "sockjs-client": "^1.6.1",
    "text-encoding-polyfill": "^0.6.7"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^20.0.0",
    "@react-native/babel-preset": "0.81.4",
    "@react-native/eslint-config": "0.81.4",
    "@react-native/metro-config": "0.81.4",
    "@react-native/typescript-config": "0.81.4",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.2",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "@types/sockjs-client": "^1.5.4",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react-native-worklets": "^0.8.0"
  }
}
